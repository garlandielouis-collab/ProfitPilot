# ── Supabase (publique — visible dans le bundle client) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (privée — NE JAMAIS mettre NEXT_PUBLIC_ devant) ─────
# Nécessaire pour les opérations admin (cleanup, migration, delete account)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Email notifications (Resend) ─────────────────────────────────
# Créez un compte gratuit sur https://resend.com
# Ajoutez votre clé API depuis https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# ── AI Pilot (Anthropic Claude) ────────────────────────────────
# Créez une clé API sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# ── URL publique de l'application ──────────────────────────────────
# Optionnel sur Vercel (VERCEL_PROJECT_PRODUCTION_URL est auto-injecté)
# Requis pour le déploiement hors Vercel (Docker, serveur dédié, etc.)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# ── Secret pour l'approbation admin des paiements ──────────────────
# Générez une chaîne aléatoire: openssl rand -hex 32
# Ce token est inclus dans l'email de notification de paiement
# L'admin clique sur le lien pour approuver automatiquement
ADMIN_APPROVAL_SECRET=votre-secret-aleatoire

# ── Sécurité admin (optionnel mais recommandé) ────────────────────
# Emails autorisés à utiliser les endpoints sensibles (cleanup, migrations)
# Laisser vide pour désactiver la restriction (déconseillé en production)
ADMIN_EMAILS=admin@example.com
