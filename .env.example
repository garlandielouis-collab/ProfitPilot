# ── Supabase (publique — visible dans le bundle client) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (privée — NE JAMAIS mettre NEXT_PUBLIC_ devant) ─────
# Nécessaire pour les opérations admin (cleanup, migration, delete account)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sécurité admin (optionnel mais recommandé) ────────────────────
# Emails autorisés à utiliser les endpoints sensibles (cleanup, migrations)
# Laisser vide pour désactiver la restriction (déconseillé en production)
ADMIN_EMAILS=admin@example.com
